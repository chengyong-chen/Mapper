import "oaidl.idl";
import "ocidl.idl";
	[
		object,
		uuid(EF327845-40A8-4AE0-9050-EA7FAD0275EA),
		dual,
		helpstring("IMapdcom Interface"),
		pointer_default(unique)
	]
	interface IMapdcom : IDispatch
	{
		[id(1), helpstring("·˝·¨OpenAtlas")] HRESULT OpenAtlas(BSTR bstrAtlas);
		[id(2), helpstring("·˝·¨OpenMap")] HRESULT OpenMap(USHORT wMapID, [out] VARIANT* varHead);
		[id(3), helpstring("·˝·¨GetMapData")] HRESULT GetMapData(USHORT wMapID, USHORT nZoom, LONG left, LONG top, LONG right, LONG bottom, [out] VARIANT* varData);
		[id(4), helpstring("·˝·¨GetMapID")] HRESULT GetMapID(BSTR bstrMap, [out] USHORT* wMapID);
		[id(5), helpstring("·˝·¨GetParentMap")] HRESULT GetParentMap(USHORT wMapID, [out] USHORT* wParentMapID);
		[id(6), helpstring("·˝·¨GetSubMap")] HRESULT GetSubMap(USHORT wMapID, DOUBLE X, DOUBLE Y, [out] USHORT* wSubMapID);
		[id(7), helpstring("·˝·¨MatchMap")] HRESULT MatchMap(DOUBLE fLongitude, DOUBLE fLatitude, [out] USHORT* wMapID);
	};

[
