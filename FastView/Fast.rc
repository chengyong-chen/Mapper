        BLOCK "040904B0"
        BEGIN
            VALUE "FileDescription", "Fast MFC Application"
            VALUE "FileVersion", "13.01.00.0"
            VALUE "InternalName", "Fast"
            VALUE "LegalCopyright", "Copyright ?Diwatu Software Ltd. 2012"
            VALUE "OriginalFilename", "Fast.EXE"
            VALUE "ProductName", "Fast Application"
            VALUE "ProductVersion", "13.01.00.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END


